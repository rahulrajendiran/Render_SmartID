PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
HARDWARE_BRIDGE_URL=http://<bridge-host>:<bridge-port>
HARDWARE_BRIDGE_KEY=

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DISABLED=false

# SMS Gateway Configuration
# Supported providers: twilio, msg91, bulk_sms, gsm_bridge, console (default)
SMS_PROVIDER=console
# For Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# For MSG91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
# For Bulk SMS
BULK_SMS_API_KEY=
BULK_SMS_SENDER_ID=
# For GSM Bridge (Raspberry Pi)
GSM_BRIDGE_URL=
GSM_BRIDGE_KEY=

# Emergency Access
EMERGENCY_PASSWORD=your-secure-emergency-password-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
