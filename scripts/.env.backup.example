# Backup Configuration
# Copy this file to .env.backup and configure your values

# Backup Directory (where local backups are stored)
BACKUP_DIR=./backups

# MongoDB Connection String (same as your backend .env)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# Retention Period (days to keep backups)
RETENTION_DAYS=30

# MongoDB Atlas API Credentials (for snapshot backups)
# Get these from: https://cloud.mongodb.com/settings/organizations
ATLAS_PROJECT_ID=
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=

# AWS S3 Configuration (optional - for cloud backup storage)
S3_BUCKET=smart-id-backups
S3_REGION=us-east-1
# AWS credentials should be configured via AWS CLI or environment variables
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Crontab example for daily backups at 2 AM:
# 0 2 * * * /path/to/scripts/backup.sh >> /var/log/smart-id-backup.log 2>&1
